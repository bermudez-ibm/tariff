# =============================================================================
# TARIFF RESILIENCE BACKEND CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# For local development, use SQLite:
DATABASE_URL=sqlite:///./storage/app.db

# For production, use PostgreSQL with connection pooling:
# DATABASE_URL=postgresql://tariff_user:SECURE_PASSWORD@postgres:5432/tariff_resilience
# Note: Never commit actual database credentials. Use environment variables or secrets management.

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# Secret key for JWT token signing
# CRITICAL: Generate a secure random key for production and rotate regularly
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-secure-random-key

# JWT token expiration time in minutes
# Default: 1440 minutes (24 hours)
# For higher security environments, reduce to 60-480 minutes and implement refresh tokens
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Development:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production: Restrict to your actual frontend domain(s)
# CORS_ORIGINS=https://tariff-resilience.example.com,https://www.tariff-resilience.example.com

# -----------------------------------------------------------------------------
# DEBUG MODE
# -----------------------------------------------------------------------------
# Set to false in production to disable debug logging and API documentation
# When false, /docs and /redoc endpoints are disabled
DEBUG=true

# Production:
# DEBUG=false

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
# Backend API port
API_PORT=9000

# -----------------------------------------------------------------------------
# RATE LIMITING (Production Recommended)
# -----------------------------------------------------------------------------
# Uncomment and configure for production deployments:
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_AUTH_PER_MINUTE=10

# -----------------------------------------------------------------------------
# ENVIRONMENT SEPARATION
# -----------------------------------------------------------------------------
# Current environment: development, staging, production
# Used for logging, monitoring, and feature flags
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# PRODUCTION DEPLOYMENT NOTES
# -----------------------------------------------------------------------------
# 1. SECRET_KEY: Rotate regularly (every 90 days recommended)
# 2. DATABASE_URL: Use connection string from secure secrets management (AWS Secrets Manager, Azure Key Vault, etc.)
# 3. CORS_ORIGINS: Whitelist only known production frontend domains
# 4. DEBUG: Always false in production
# 5. Security Headers: Automatically applied by SecurityHeadersMiddleware
# 6. HTTPS: Ensure TLS/SSL is configured at load balancer or reverse proxy level
# 7. Monitoring: Configure APM and logging (see README deployment section)
