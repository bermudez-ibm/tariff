# =============================================================================
# TARIFF RESILIENCE FRONTEND CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
# Base URL for the backend API
# Development (local):
VITE_API_URL=http://localhost:9000

# Development (docker-compose):
# Use 127.0.0.1 instead of localhost for IPv4 resolution on macOS
# VITE_API_URL=http://127.0.0.1:9000

# Production: Set to your backend API gateway URL
# VITE_API_URL=https://api.tariff-resilience.example.com

# -----------------------------------------------------------------------------
# ENVIRONMENT SEPARATION
# -----------------------------------------------------------------------------
# Current environment: development, staging, production
# Used for feature flags and environment-specific behavior
# VITE_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# PRODUCTION DEPLOYMENT NOTES
# -----------------------------------------------------------------------------
# 1. VITE_API_URL: Must point to production API gateway or backend load balancer
# 2. Ensure CORS is properly configured on backend to allow frontend domain
# 3. Frontend should be served via CDN with HTTPS enabled
# 4. Consider implementing:
#    - Content Security Policy (CSP) headers
#    - Subresource Integrity (SRI) for external scripts
#    - Rate limiting at CDN level
# 5. Build optimization: npm run build creates optimized production bundle
