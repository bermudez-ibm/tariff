# Docker Compose Environment Variables
# Copy this file to .env in the project root for docker-compose deployment

# PostgreSQL Configuration
POSTGRES_PASSWORD=changeme_use_secure_password_in_production

# Backend Configuration
SECRET_KEY=changeme_generate_secure_random_key_in_production
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Production checklist:
# 1. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Use strong POSTGRES_PASSWORD (min 16 characters, mixed case, numbers, symbols)
# 3. Set DEBUG=false
# 4. Update CORS_ORIGINS in docker-compose.yml to match production frontend domain
# 5. Configure TLS/SSL at load balancer or reverse proxy
# 6. Enable monitoring and logging
